

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog App</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/styles/main.css">
</head>

<body>
<%- include('partials/header.ejs') %>
    <div class="container">

        <h1>My blog</h1>
        <a href="/new" class="btn">Start a new Blog</a>

        <% if (posts.length === 0) { %>
            <p class="empty">No posts yet. Write the first one!</p>
        <% } else { %>
            <% posts.forEach(post => { %>
                <article class="post-card">
                    <h2>
                        <a href="/posts/<%= post.id %>" class="post-title"><%= post.title %></a>
                    </h2>

                    <p><%= post.content %></p>

                    <div class="post-actions">
                        <a href="/posts/<%= post.id %>" class="btn small">Read</a>
                        <a href="/posts/<%= post.id %>/edit" class="btn small secondary">Edit</a>

                        <form action="/posts/<%= post.id %>/delete" method="POST" class="inline-form">
                            <button type="submit" class="btn small danger">Delete</button>
                        </form>
                    </div>
                </article>
            <% }) %>
        <% } %>

    </div>
    
<%- include('partials/footer.ejs') %>

</body>

</html>

